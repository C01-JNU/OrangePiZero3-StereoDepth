#version 450

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

// 第一阶段：输入缓冲区 -> 中间结果
layout(binding = 0) buffer InputBuffer {
    uint data[];
} inputBuffer;

layout(binding = 1) buffer Stage1Output {
    uint data[];
} stage1Output;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < 1024) {
        // 第一阶段计算：乘以2
        stage1Output.data[idx] = inputBuffer.data[idx] * 2;
    }
}
