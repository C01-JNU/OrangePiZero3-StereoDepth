// minimal_test/1level/compute.comp
#version 450

// 使用描述符集布局
layout(set = 0, binding = 0) buffer StorageBuffer {
    uint data[];
} storageBuffer;

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < 1024) {
        storageBuffer.data[idx] = idx * 2;
    }
}
